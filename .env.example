# Copy to .env and fill in. .env is loaded automatically by analyze.py.

# OpenAI-compatible endpoint used by --ai.
# Point OPENAI_BASE_URL at any provider that speaks the OpenAI chat API
# (OpenAI, OpenRouter, Perplexity, Groq, LM Studio, Ollama, etc.).
# For actually-recent news, use a provider/model with browsing.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Discord webhook used by --discord (optional; can also pass --discord-url).
DISCORD_WEBHOOK_URL=

# yfinance-cache is used automatically when installed. Cache lives at
# ./.cache/yfinance-cache (relative to cwd) by default.
# Override with STOCK_TA_CACHE_DIR, or disable with STOCK_TA_CACHE_DISABLE=1.
# STOCK_TA_CACHE_DIR=.cache/yfinance-cache
# STOCK_TA_CACHE_DISABLE=1

# Logging level: DEBUG, INFO (default), WARNING, ERROR.
# STOCK_TA_LOG_LEVEL=INFO

# Log destination: a file path (default "log.txt"),
# "-" or "stderr" for stderr, "stdout" for stdout.
# STOCK_TA_LOG_FILE=log.txt
