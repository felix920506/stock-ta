# Copy to .env and fill in. .env is loaded automatically by analyze.py.

# OpenAI-compatible endpoint used by --ai.
# Point OPENAI_BASE_URL at any provider that speaks the OpenAI chat API
# (OpenAI, OpenRouter, Perplexity, Groq, LM Studio, Ollama, etc.).
# For actually-recent news, use a provider/model with browsing.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Discord webhook used by --discord (optional; can also pass --discord-url).
DISCORD_WEBHOOK_URL=

# yfinance-cache is used automatically when installed. Set to 1 to bypass
# it and go directly to yfinance (e.g. for debugging cache issues).
# STOCK_TA_CACHE_DISABLE=1
